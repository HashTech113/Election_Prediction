# Build context for backend/kerala/ — Railway sets Root Directory here, so
# paths in this file are relative to backend/kerala/, not the repo root.

# Local dev / VCS / IDE
.git/
.github/
.vscode/
.idea/
*.log
.env
.env.*
.venv/
venv/

# Python build artefacts
**/__pycache__/
**/*.pyc
**/*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Trained model checkpoints — large, regenerated by train.py, not used by API
checkpoints/

# Platform metadata
.vercel/
.railway/

# Docs
README.md
.gitignore
.gitattributes
