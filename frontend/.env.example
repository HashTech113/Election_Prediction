# Frontend (Vite) — production env vars set in Vercel project settings.
# For local dev, copy this file to `.env.local` and adjust the URLs below.

# Kerala backend (Railway service #1)
VITE_API_KERALA_URL=http://localhost:8001

# Tamil Nadu backend (Railway service #2)
VITE_API_TN_URL=http://localhost:8002

# --- Optional Vite dev server overrides ---
# VITE_DEV_HOST=0.0.0.0
# VITE_DEV_PORT=5173

# --- Optional deployment integrity checks ---
# Set these to detect stale backend deployments. Get SHA from
# `${VITE_API_KERALA_URL}/api/predictions/meta -> source_sha256`.
# VITE_EXPECTED_PREDICTIONS_SHA256=
# VITE_EXPECTED_API_VERSION=
